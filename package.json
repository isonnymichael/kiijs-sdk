{
  "name": "kiijs-sdk",
  "version": "0.1.1",
  "author": "kiiglobal.io <dev@kiiglobal.io>",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/KiiChain/kiijs-sdk"
  },
  "overrides": {
    "chalk": "5.3.0",
    "strip-ansi": "7.1.0",
    "color-convert": "2.0.1",
    "color-name": "1.1.4",
    "is-core-module": "2.13.1",
    "error-ex": "1.3.2",
    "has-ansi": "5.0.1"
  },
  "license": "SEE LICENSE IN LICENSE",
  "publishConfig": {
    "access": "public"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "turbo run clean",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "eslint --fix packages/*/src/",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx}' --ignore-path .prettierignore",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,tsx}' --ignore-path .prettierignore",
    "test": "turbo run test",
    "test:evm": "cd packages/evm && yarn test",
    "test:proto": "cd packages/proto && yarn test",
    "test:utils": "cd packages/utils && yarn test",
    "test:rwa": "cd packages/rwa && yarn test",
    "test:ci": "turbo run test:ci",
    "test:evm:ci": "cd packages/evm && yarn test:ci",
    "test:proto:ci": "cd packages/proto && yarn test:ci",
    "codegen": "turbo run codegen",
    "symlink": "symlink-workspace --logLevel error",
    "postinstall": "yarn symlink"
  },
  "devDependencies": {
    "@types/bun": "^1.2.18",
    "@types/jest": "^29.5.11",
    "@types/node": "^24.9.2",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "copyfiles": "^2.4.1",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "eslint-plugin-unused-imports": "^4.0.0",
    "jest": "^29.6.2",
    "prettier": "3.6.2",
    "rimraf": "4.4.1",
    "strip-ansi": "7.1.0",
    "symlink-workspace": "^1.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "turbo": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@4.10.3"
}
