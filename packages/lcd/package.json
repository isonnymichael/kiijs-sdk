{
  "name": "@kiichain/kiijs-lcd",
  "version": "0.1.0",
  "author": "kiiglobal.io <dev@kiiglobal.io>",
  "description": "JS SDK for kiichain LCD endpoints",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "homepage": "https://github.com/KiiChain/kiijs-sdk",
  "license": "Apache-2.0",
  "overrides": {
    "chalk": "5.3.0",
    "strip-ansi": "7.1.0",
    "color-convert": "2.0.1",
    "color-name": "1.1.4",
    "is-core-module": "2.13.1",
    "error-ex": "1.3.2",
    "has-ansi": "5.0.1"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "directory": "dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KiiChain/kiijs-sdk"
  },
  "bugs": {
    "url": "https://github.com/KiiChain/kiijs-sdk/issues"
  },
  "scripts": {
    "clean": "npx rimraf dist",
    "build": "bun run ../../scripts/build.ts",
    "codegen": "npx tsx scripts/codegen.ts",
    "lint": "npx eslint src/"
  },
  "devDependencies": {
    "swagger-typescript-api": "^13.2.13",
    "tsx": "^4.20.6"
  },
  "keywords": [],
  "packageManager": "yarn@4.10.3"
}
