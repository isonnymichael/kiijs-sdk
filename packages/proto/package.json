{
  "name": "@kiichain/kiijs-proto",
  "version": "0.2.1",
  "author": "kiiglobal.io <dev@kiiglobal.io>",
  "type": "module",
  "description": "JS SDK for kiichain protofiles",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "homepage": "https://github.com/KiiChain/kiijs-sdk",
  "license": "Apache-2.0",
  "overrides": {
    "chalk": "5.3.0",
    "strip-ansi": "7.1.0",
    "color-convert": "2.0.1",
    "color-name": "1.1.4",
    "is-core-module": "2.13.1",
    "error-ex": "1.3.2",
    "has-ansi": "5.0.1"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "directory": "dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KiiChain/kiijs-sdk"
  },
  "bugs": {
    "url": "https://github.com/KiiChain/kiijs-sdk/issues"
  },
  "scripts": {
    "clean": "npx rimraf dist",
    "build": "bun run ../../scripts/build.ts",
    "codegen": "npx ts-node scripts/codegen.ts",
    "lint": "echo 'Skipping lint for generated proto files'",
    "test": "yarn jest",
    "test:ci": "yarn jest",
    "test:watch": "yarn jest --watch"
  },
  "devDependencies": {
    "@cosmology/telescope": "^1.10.0",
    "@types/jest": "^29.5.14",
    "dotenv": "16.4.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.1"
  },
  "dependencies": {
    "@cosmjs/amino": "^0.33.1",
    "@cosmjs/encoding": "^0.33.1",
    "@cosmjs/math": "^0.33.1",
    "@cosmjs/proto-signing": "^0.33.1",
    "@cosmjs/stargate": "^0.33.1",
    "@cosmology/lcd": "^0.14.0"
  },
  "keywords": [],
  "packageManager": "yarn@4.10.3"
}
