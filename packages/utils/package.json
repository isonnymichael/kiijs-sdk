{
  "name": "@kiichain/kiijs-utils",
  "version": "0.1.3",
  "type": "module",
  "author": "kiiglobal.io <devs@kiiglobal.io>",
  "description": "TypeScript utility library for the Kii blockchain",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "sideEffects": false,
  "overrides": {
    "chalk": "5.3.0",
    "strip-ansi": "7.1.0",
    "color-convert": "2.0.1",
    "color-name": "1.1.4",
    "is-core-module": "2.13.1",
    "error-ex": "1.3.2",
    "has-ansi": "5.0.1"
  },
  "scripts": {
    "prebuild": "npx rimraf dist",
    "build": "bun run ../../scripts/build.ts",
    "docs": "npx typedoc --out docs",
    "test": "npx jest",
    "test:ci": "npx jest",
    "lint": "npx eslint src/"
  },
  "homepage": "https://github.com/KiiChain/kiijs-sdk#readme",
  "keywords": [
    "kii",
    "javascript",
    "typescript",
    "node",
    "utils"
  ],
  "repository": "git@github.com:KiiChain/kiijs-sdk.git",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "peerDependencies": {
    "dotenv": "16.4.7",
    "ethers": "^6.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "ethers": "^6.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.1"
  },
  "dependencies": {
    "@kiichain/kiijs-proto": "workspace:^",
    "npm": "^11.4.1",
    "ts-node": "^10.9.2"
  },
  "packageManager": "yarn@4.10.3"
}
